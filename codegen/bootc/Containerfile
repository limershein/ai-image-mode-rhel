# Example: an AI powered sample application is embedded as a systemd service
# via Podman quadlet files in /usr/share/containers/systemd
#
# from recipes/natural_language_processing/codegen, run
# 'make bootc'

FROM registry.redhat.io/rhel10/rhel-bootc
ARG SSHPUBKEY

# The --build-arg "SSHPUBKEY=$(cat ~/.ssh/id_rsa.pub)" option inserts your
# public key into the image, allowing root access via ssh.
RUN set -eu; mkdir -p /usr/ssh && \
    echo 'AuthorizedKeysFile /usr/ssh/%u.keys .ssh/authorized_keys .ssh/authorized_keys2' >> /etc/ssh/sshd_config.d/30-auth-system.conf && \
    echo ${SSHPUBKEY} > /usr/ssh/root.keys && chmod 0600 /usr/ssh/root.keys

ARG RECIPE=codegen

# Add quadlet files to setup system to automatically run AI application on boot
COPY build/${RECIPE}.kube build/${RECIPE}.yaml /usr/share/containers/systemd

# Install .image quadlet files for each workload container
COPY build/${RECIPE}-app.image build/${RECIPE}-model.image build/${RECIPE}-server.image \
     /usr/share/containers/systemd

# Configure logically-bound images so bootc pre-fetches the workload
# containers during installation. Images are stored in /usr/lib/bootc/storage
# and available immediately at boot without an on-demand pull.
RUN mkdir -p /usr/lib/bootc/bound-images.d && \
    ln -s /usr/share/containers/systemd/${RECIPE}-app.image    /usr/lib/bootc/bound-images.d/ && \
    ln -s /usr/share/containers/systemd/${RECIPE}-model.image  /usr/lib/bootc/bound-images.d/ && \
    ln -s /usr/share/containers/systemd/${RECIPE}-server.image /usr/lib/bootc/bound-images.d/

# First-boot service to register /usr/lib/bootc/storage as an additional
# image store in /etc/containers/storage.conf. This cannot be baked into
# the image because bootc-image-builder's osbuild sandbox validates all
# additionalimagestores paths and fails if they don't exist.
COPY build/configure-image-store.sh /usr/libexec/configure-image-store.sh
RUN chmod 0755 /usr/libexec/configure-image-store.sh
COPY build/configure-image-store.service /usr/lib/systemd/system/configure-image-store.service
RUN systemctl enable configure-image-store.service

# Added for running as an OCI Container to prevent Overlay on Overlay issues.
VOLUME /var/lib/containers
